# ============================================================
# Multi-Modal Physiological Monitoring System – Environment
# Copy this file to .env and adjust values for your setup.
# .env is gitignored; this file is safe to commit.
# ============================================================

# ── Video capture ────────────────────────────────────────────
# Camera device index (0 = first webcam, 1 = second, etc.)
WEBCAM_INDEX=0

# Capture resolution and frame rate
FRAME_WIDTH=640
FRAME_HEIGHT=480
FPS=20

# ── Signal processing windows (seconds) ─────────────────────
RPPG_WINDOW_SEC=15
RESPIRATION_WINDOW_SEC=15
BLINK_WINDOW_SEC=10
PERCLOS_WINDOW_SEC=60
FUSION_WINDOW_SEC=60

# ── Flask API ────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Comma-separated allowed CORS origins (use * for development only)
CORS_ORIGINS=*

# ── Database ─────────────────────────────────────────────────
# Path to the SQLite database file (created automatically)
DB_PATH=data/metrics.db

# How often to persist metrics to DB (every N frames)
DB_SAVE_INTERVAL=20

# Maximum rows kept in the metrics table before auto-pruning
DB_MAX_ROWS=100000

# ── Logging ──────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_FILE=physiological_system.log
# Max log file size in bytes before rotation (default 10 MB)
LOG_MAX_BYTES=10485760
# Number of rotated backup files to keep
LOG_BACKUP_COUNT=5

# ── Face detection confidence ────────────────────────────────
FACE_DETECTION_CONFIDENCE=0.7
FACE_MESH_CONFIDENCE=0.5
FACE_MESH_TRACKING_CONFIDENCE=0.5

# ── Alert thresholds ─────────────────────────────────────────
# These are hard-coded in config.py. Override there, or extend
# config.py to read from env vars if per-deployment tuning is needed.
